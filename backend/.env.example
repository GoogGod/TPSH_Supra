DJANGO_ENV=development
SECRET_KEY=your-secret-key-here  # required in production
DJANGO_DB_PATH=/var/data/db.sqlite3
ALLOWED_HOSTS=your-domain.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com
JWT_ACCESS_TOKEN_MINUTES=480
JWT_REFRESH_TOKEN_DAYS=30
DRF_ANON_THROTTLE_RATE=60/minute
DRF_USER_THROTTLE_RATE=240/minute
DRF_LOGIN_THROTTLE_RATE=10/minute

# Optional: override ML storage paths (useful with Render persistent disk)
# ML_DATA_DIR=/var/data/ml_data
# ML_DATA_RAW=/var/data/ml_data/data/raw
# ML_DATA_PROCESSED=/var/data/ml_data/data/processed
# ML_DATA_PREDICTED=/var/data/ml_data/data/predicted
# ML_MODELS_DIR=/var/data/ml_data/models
